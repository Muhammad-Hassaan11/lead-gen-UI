# Backend (defaults are sensible — change only if you know why).
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO

# Anti-ban: sequential Maps requests with jittered delay.
MAPS_MIN_DELAY_SEC=5
MAPS_MAX_DELAY_SEC=10

# Concurrency for website-targeted scrapers (email, facebook).
WEBSITE_CONCURRENCY=5
WEBSITE_TIMEOUT_SEC=20

# Phone region default (ISO 3166-1 alpha-2).
DEFAULT_PHONE_REGION=US

# Run Playwright headless. Set to false to watch what's happening.
HEADLESS=true
